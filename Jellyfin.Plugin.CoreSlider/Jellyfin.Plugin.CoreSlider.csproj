<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <!-- <JellyfinVersion>10.10.0</JellyfinVersion> -->
        <JellyfinVersion>10.11.0</JellyfinVersion>
        <TargetFramework Condition="$(JellyfinVersion.StartsWith('10.11.0'))">net9.0</TargetFramework>
        <TargetFramework Condition="'$(JellyfinVersion)' == '10.10.0'">net8.0</TargetFramework>
        <RootNamespace>Jellyfin.Plugin.CoreSlider</RootNamespace>
        <AssemblyName>Jellyfin.Plugin.CoreSlider</AssemblyName>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Jellyfin.Model" Version="$(JellyfinVersion)">
            <ExcludeAssets>runtime</ExcludeAssets>
        </PackageReference>
        <PackageReference Include="Jellyfin.Controller" Version="$(JellyfinVersion)">
            <ExcludeAssets>runtime</ExcludeAssets>
        </PackageReference>
        <PackageReference Include="Newtonsoft.Json" Version="13.0.1" />
    </ItemGroup>

    <ItemGroup>
        <EmbeddedResource Include="Configuration\configPage.html" />
    </ItemGroup>
</Project>